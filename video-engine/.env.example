# =============================================
# VimaClip - Motor de Vídeo
# Variáveis de Ambiente
# =============================================
# INSTRUÇÕES:
# 1. Copie este arquivo: copy .env.example .env
# 2. Preencha os valores abaixo
# =============================================

# Chave da API do Groq para transcrição de áudio (Whisper na nuvem)
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Diretório para armazenar vídeos temporários dentro do container
TEMP_DIR=/app/temp_videos

# Duração máxima permitida para vídeos (em segundos)
# Padrão: 600 segundos = 10 minutos
MAX_VIDEO_DURATION=600
